# ─────────────────────────────────────────────────────────────
#  MOMENTMINT — Environment Variables
#  Copy this file to .env and fill in your keys
#  NEVER commit .env to GitHub
# ─────────────────────────────────────────────────────────────

# Anthropic Claude API — SERVER SIDE ONLY (no VITE_ prefix)
# Used in api/analyze.ts — never exposed to browser
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Tether WDK — filled in by dev during WDK integration
# Get from: docs.wdk.tether.io
WDK_NETWORK=mainnet
WDK_API_KEY=your_wdk_key_here
